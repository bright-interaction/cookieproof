# CookieProof Environment Configuration
# Copy to .env and fill in values before deploying.

# --- Server ---
PORT=3100
DB_PATH=/data/consent-proofs.db

# --- API Authentication ---
COOKIEPROOF_API_KEY=

# --- Webhooks ---
WEBHOOK_URL=
WEBHOOK_SECRET=

# --- Email (at least one required for verification, password reset, alerts) ---
# Option A: Resend (preferred)
RESEND_API_KEY=
RESEND_FROM=CookieProof <noreply@send.yourdomain.com>

# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Billing (Mollie — all three required to enable billing) ---
MOLLIE_API_KEY=
MOLLIE_WEBHOOK_URL=https://yourdomain.com/api/billing/webhook
MOLLIE_REDIRECT_URL=https://yourdomain.com/billing

# --- CORS (comma-separated allowed origins) ---
ALLOWED_ORIGINS=https://yourdomain.com

# --- Admin ---
ADMIN_EMAIL=admin@yourdomain.com

# --- PDF Generation ---
GOTENBERG_URL=http://gotenberg:3000

# --- Data Retention (days, default 1095 = 3 years) ---
RETENTION_DAYS=1095

# --- Alerts ---
ALERT_CHECK_INTERVAL_HOURS=6
ALERT_EMAIL_ENABLED=true
